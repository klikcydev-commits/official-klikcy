# Public site URL (canonicals, sitemap, contact emails)
NEXT_PUBLIC_SITE_URL=https://www.klikcy.com
SITE_URL=https://www.klikcy.com

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-PF4N2DXK
NEXT_PUBLIC_GA_ID=G-PHEFSHYPR7
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Contact page display email (client-assembled; optional split parts)
NEXT_PUBLIC_CONTACT_EMAIL=build@klikcy.com
NEXT_PUBLIC_CONTACT_EMAIL_USER=build
NEXT_PUBLIC_CONTACT_EMAIL_DOMAIN=klikcy.com

# Contact form HMAC (server-only — signs render timestamp for anti-bot time gate)
CONTACT_FORM_SECRET=generate-a-long-random-string

# Optional Upstash Redis for distributed rate limiting (see src/lib/rate-limit.ts)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# SMTP (server-only — never expose to client)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=build@klikcy.com
SMTP_PASS=your-smtp-password
CONTACT_EMAIL=build@klikcy.com
