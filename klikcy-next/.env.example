# Public site URL (used in canonicals, sitemaps, and contact emails)
NEXT_PUBLIC_SITE_URL=https://www.klikcy.com

# Google Tag Manager (from old klikcy.com — GA4 G-PHEFSHYPR7 loads via this container)
NEXT_PUBLIC_GTM_ID=GTM-PF4N2DXK

# GA4 measurement ID (reference only — do not load gtag.js separately when using GTM)
NEXT_PUBLIC_GA_ID=G-PHEFSHYPR7

# Google Search Console — verified via DNS TXT on klikcy.com (no HTML meta tag required).
# To add HTML-tag verification later, set the real code from Search Console:
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: shown on the contact page (not secret)
NEXT_PUBLIC_CONTACT_EMAIL=your-inbox@klikcy.com

# Contact API base URL (static export — run server/index.mjs separately)
NEXT_PUBLIC_CONTACT_API_URL=http://127.0.0.1:8787

# Contact API (Node server — see ../server/index.mjs)
CONTACT_API_PORT=8787
SITE_URL=https://www.klikcy.com

# SMTP (Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=your-smtp-user@klikcy.com
SMTP_PASS=your-smtp-password
CONTACT_EMAIL=your-inbox@klikcy.com
